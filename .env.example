# Copy this file to `.env` and edit. Everything is optional — sensible
# defaults are baked into config.py.

# --- Database --------------------------------------------------------------
# Default is a local SQLite file — no install required. You do NOT need
# PostgreSQL for this project. If you'd rather use the PostgreSQL you already
# have installed, uncomment one of these (and `pip install "psycopg[binary]"`):
# DATABASE_URL=sqlite:///./gramsynth.db
# DATABASE_URL=postgresql+psycopg://gramsynth:secret@localhost:5432/gramsynth

# --- Paths -----------------------------------------------------------------
# STYLEGAN_DIR=../stylegan2-ada-pytorch
# RUNS_DIR=./runs
# DATA_DIR=./data
# PYTHON_BIN=python

# --- Front-end origins allowed by CORS ------------------------------------
# CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# --- Demo mode -------------------------------------------------------------
# Simulate the whole pipeline in-process (no GPU, no StyleGAN scripts needed).
# Great for trying the real-time UI end-to-end on your laptop.
# MOCK=1
